PORT=4000

# Google Sign-In — OAuth client ID(s) allowed to mint ID tokens (comma-separated).
# Used by be/src (modular app). Not used by be/server.js.
GOOGLE_CLIENT_IDS=
# Alternative: single ID
# GOOGLE_CLIENT_ID=

# Demo username/password login (be/src only; defaults: admin / changeme)
DEMO_USERNAME=admin
DEMO_PASSWORD=changeme

# Telegram — create a bot via @BotFather
TELEGRAM_BOT_TOKEN=
# Chat ID (user or group) where approval messages are sent (numeric, e.g. 123456789)
TELEGRAM_ADMIN_CHAT_ID=

# Optional. If set, must match Telegram setWebhook secret_token; sent as X-Telegram-Bot-Api-Secret-Token
TELEGRAM_WEBHOOK_SECRET=

# Not read by the app — optional note for you when calling setWebhook (e.g. https://host/telegram/webhook)
PUBLIC_BASE_URL=
