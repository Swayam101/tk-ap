PORT=4000

# Telegram Bot A — create a bot via @BotFather
TELEGRAM_BOT_TOKEN=

# Chat/group ID where approval messages are sent (numeric, e.g. 123456789)
TELEGRAM_ADMIN_CHAT_ID=

# Recommended. Must match the secret_token you pass to setWebhook.
# Sent by Telegram as X-Telegram-Bot-Api-Secret-Token on every webhook call.
TELEGRAM_WEBHOOK_SECRET=

# Base URL for your API (used for webhook setup)
# e.g. https://your-host.example.com
API_BASE_URL=
